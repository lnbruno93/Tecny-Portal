# Copia este archivo como .env.local y completá los valores para desarrollo local.
# NUNCA commitees .env.local — ya está en .gitignore.

# URL del backend en local (Railway en producción lo sobreescribe automáticamente)
VITE_API_URL=http://localhost:3001

# Nota: NO usamos @sentry/react. Decisión durable (ver ARCHITECTURE.md §8) por
# tamaño de bundle. En su lugar, lib/reportError.js implementa un reporter
# custom que postea a /api/client-errors y el backend lo reenvía a Sentry server-side.
