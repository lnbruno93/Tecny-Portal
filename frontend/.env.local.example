# Copia este archivo como .env.local y completá los valores para desarrollo local.
# NUNCA commitees .env.local — ya está en .gitignore.

# URL del backend en local (Railway en producción lo sobreescribe automáticamente)
VITE_API_URL=http://localhost:3001

# Sentry DSN para error tracking del frontend (opcional — dejar vacío si no se usa).
# Decisión durable (ver ARCHITECTURE.md §8): NO usamos @sentry/react (suma ~30KB
# gz al bundle). En su lugar, lib/reportError.js implementa un reporter custom
# que postea a /api/client-errors. El backend lo reenvía a Sentry con el commit
# build SHA para que los stacktraces minificados sean legibles.
VITE_SENTRY_DSN=
