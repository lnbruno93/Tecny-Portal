# Template de credenciales para scripts/ipro-backup.sh.
#
# CÓMO USAR:
#   1. Copiar este archivo a ~/.ipro-backup.env (NO al repo)
#        cp scripts/ipro-backup.env.example ~/.ipro-backup.env
#   2. Reemplazar los placeholders con los valores reales (sin las comillas).
#   3. Restringir permisos: chmod 600 ~/.ipro-backup.env
#   4. Validar que el script lo lee: ~/bin/ipro-backup.sh
#
# Las 4 variables son REQUERIDAS — el script aborta si falta alguna.

# ─── DATABASE_PUBLIC_URL ──────────────────────────────────────────────────
# Connection string al Postgres de Railway via TCP Proxy (Public Network).
# Para obtenerla:
#   Railway → production → Postgres-AueP → botón Connect → tab "Public Network"
#   → copiar la "Connection URL" (con el password en claro: click "show").
# Formato: postgresql://postgres:PASS@<host>.proxy.rlwy.net:<port>/railway
# Si Railway rota credenciales o cambia el proxy, hay que actualizar acá.
DATABASE_PUBLIC_URL="postgresql://postgres:PASS@HOST.proxy.rlwy.net:PORT/railway"

# ─── B2_KEY_ID + B2_APP_KEY ───────────────────────────────────────────────
# Application Key bucket-scoped del bucket de backups. Generar en:
#   Backblaze UI → App Keys → Add a New Application Key
#   · Scope: SOLO el bucket de backups (no "all buckets")
#   · Permissions: Read & Write
#   · Allow List All Bucket Names: No
# La key se muestra UNA SOLA VEZ al crearla — copiar inmediatamente.
B2_KEY_ID="TU_KEY_ID"
B2_APP_KEY="TU_APPLICATION_KEY"

# ─── B2_BUCKET ────────────────────────────────────────────────────────────
# Nombre del bucket privado donde se suben los dumps. Por convención:
#   ipro-backups-prod   (producción)
#   ipro-backups-staging (si llegáramos a backupear staging algún día)
B2_BUCKET="ipro-backups-prod"
