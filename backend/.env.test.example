# .env.test.example — template versionado de las variables de test.
#
# QUÉ HACER:
#   1. Copiar este archivo a `backend/.env.test`:
#        cp backend/.env.test.example backend/.env.test
#   2. Los valores default abajo funcionan tal cual con el `docker-compose.yml`
#      del repo root (user/pass/db matchean lo que docker levanta).
#   3. `docker-compose up -d --wait` desde el root del repo.
#   4. `cd backend && npm test` — corre contra el PG local.
#
# ESTAS VALUES SON DE TEST ONLY — no son secretos reales. Cualquier dev
# puede usarlas tal cual. NO USAR EN PRODUCCIÓN.
#
# El CI usa las mismas 4 vars (ver .github/workflows/ci.yml → env). Si
# cambian acá, actualizar el CI también.

# Conexión al Postgres local levantado por docker-compose.yml (repo root).
# user/password/db matchean exactamente lo que docker-compose crea.
DATABASE_URL=postgresql://ipro:testpass@localhost:5432/ipro_test

# JWT_SECRET — cualquier string ≥16 chars sirve.
JWT_SECRET=local-test-jwt-secret-not-for-production
JWT_EXPIRES_IN=8h

# TWOFA_ENCRYPTION_KEY — 64 chars hex (32 bytes) obligatorio para tests
# de 2FA en startup. Sin esto el server crashea al bootear.
TWOFA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# NODE_ENV=test hace que algunos módulos skipeen features de prod
# (envío de emails, rate-limit fanáticos, etc).
NODE_ENV=test
