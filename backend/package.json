{
  "name": "tecny-portal-backend",
  "version": "1.0.1",
  "description": "Tecny — API Backend",
  "main": "server.js",
  "scripts": {
    "start": "npm run migrate && node server.js",
    "dev": "nodemon server.js | pino-pretty --colorize --translateTime 'SYS:HH:MM:ss'",
    "test": "jest --runInBand",
    "test:local": "cd .. && docker compose up -d --wait && cd backend && jest --runInBand",
    "test:local:down": "cd .. && docker compose down",
    "test:local:reset": "cd .. && docker compose down -v && docker compose up -d --wait",
    "lint": "eslint src/",
    "migrate": "node-pg-migrate -m migrations up",
    "migrate:down": "node-pg-migrate -m migrations down",
    "migrate:create": "node-pg-migrate -m migrations create",
    "load-test": "node loadtest/run.js"
  },
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "uuid": "^11.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@sentry/node": "^10.53.1",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^8.0.4",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "resend": "^6.13.0",
    "speakeasy": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "autocannon": "^8.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.4",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
