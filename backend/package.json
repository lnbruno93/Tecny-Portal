{
  "name": "ipro-portal-backend",
  "version": "1.0.0",
  "description": "iPro Portal — API Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js | pino-pretty --colorize --translateTime 'SYS:HH:MM:ss'",
    "test": "jest --runInBand",
    "migrate": "node-pg-migrate -m migrations up",
    "migrate:down": "node-pg-migrate -m migrations down",
    "migrate:create": "node-pg-migrate -m migrations create"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@sentry/node": "^10.53.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "jest": "^30.4.2",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.4",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
