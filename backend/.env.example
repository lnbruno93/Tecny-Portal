# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Base de datos ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ipro_portal

# Pool de conexiones (opcionales — valores por defecto entre paréntesis)
# DB_POOL_MAX=20
# DB_CONN_TIMEOUT=5000
# DB_IDLE_TIMEOUT=30000
# Cortafuegos contra queries colgadas (ver src/config/database.js)
# DB_STATEMENT_TIMEOUT=15000
# DB_QUERY_TIMEOUT=15000
# DB_IDLE_TX_TIMEOUT=10000

# ─── Autenticación JWT ───────────────────────────────────────
# REQUERIDO — mínimo 32 caracteres. Generar con: openssl rand -hex 32
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=8h

# ─── 2FA (TOTP) ──────────────────────────────────────────────
# REQUERIDO — 32 bytes hex (64 chars). Generar con: openssl rand -hex 32
# Si la key cambia, todos los secrets TOTP cifrados quedan ilegibles
# (rotación requiere migración + re-enrolment de cada usuario).
# IMPORTANTE: usar keys DISTINTAS en staging y producción.
TWOFA_ENCRYPTION_KEY=change_this_to_64_hex_chars_use_openssl_rand_hex_32

# ─── CORS ────────────────────────────────────────────────────
# URL del frontend (Netlify). Múltiples orígenes separados por coma.
# NUNCA usar * en producción.
CORS_ORIGIN=https://tudominio.com

# ─── Rate limiting global ────────────────────────────────────
# Tope de requests por IP cada 15 min, aplicado a TODOS los endpoints
# (excepto /health y /ready). Default 300 — alcanza para uso normal.
# Subir temporalmente para load testing (5000+) o campañas con pico
# legítimo (1000+); volver al default después.
# Multi-instance (Railway 2 réplicas): el counter es compartido vía
# PostgresRateLimitStore (tabla rate_limit_entries) — ver src/app.js.
# GLOBAL_RATE_LIMIT_MAX=300

# ─── Logging ─────────────────────────────────────────────────
# Niveles: trace | debug | info | warn | error
# LOG_LEVEL=info

# ─── Auditoría ───────────────────────────────────────────────
# Días de retención para audit_logs. Job interno corre cada 24h y borra
# las filas más viejas. Mínimo 30 (validado en lib/audit.js). Default 365.
# AUDIT_RETENCION_DIAS=365

# ─── Monitoreo de errores (Sentry) ───────────────────────────
# Dejar vacío para deshabilitar
# SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456

# ─── Anthropic (OCR de comprobantes) ─────────────────────────
# Generar en console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Scripts de migración (solo para setup inicial) ──────────
# API key de Google Sheets — generar en Google Cloud Console
# SHEETS_API_KEY=
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_EMAIL=
# ADMIN_NOMBRE=Administrador
