# ─── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Base de datos ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ipro_portal

# Pool de conexiones (opcionales — valores por defecto entre paréntesis)
# DB_POOL_MAX=10
# DB_CONN_TIMEOUT=5000
# DB_IDLE_TIMEOUT=30000

# ─── Autenticación JWT ───────────────────────────────────────
# REQUERIDO — mínimo 32 caracteres. Generar con: openssl rand -hex 32
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────
# URL del frontend (Index.html). Múltiples orígenes separados por coma.
# NUNCA usar * en producción.
CORS_ORIGIN=https://tudominio.com

# ─── Logging ─────────────────────────────────────────────────
# Niveles: trace | debug | info | warn | error
# LOG_LEVEL=info

# ─── Monitoreo de errores (Sentry) ───────────────────────────
# Dejar vacío para deshabilitar
# SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456

# ─── Anthropic (OCR de comprobantes) ─────────────────────────
# Generar en console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Scripts de migración (solo para setup inicial) ──────────
# API key de Google Sheets — generar en Google Cloud Console
# SHEETS_API_KEY=
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_EMAIL=
# ADMIN_NOMBRE=Administrador
