# Copia este archivo como .env.local y completá los valores para desarrollo local.
# NUNCA commitees .env.local — ya está en .gitignore.

# URL del backend en local (Railway en producción lo sobreescribe automáticamente)
VITE_API_URL=http://localhost:3001

# hCaptcha site key — usado en el flow público de aceptar invitación de
# super-admin (/aceptar-invitacion). Mismo pattern que /login del portal.
# Default (usado si la var no está seteada): test sitekey oficial de hCaptcha
# que siempre pasa — apto para dev/local.
# En prod (Netlify), setear la sitekey real de la cuenta hCaptcha de Tecny
# (mismo valor que la del portal frontend). No es secret — es visible en el
# HTML del cliente — pero debe ser la real para que la verificación server-side
# no sea bypass.
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
