# Copia este archivo como e2e/.env y completá los valores para tu entorno local.
# NUNCA commitees e2e/.env — ya está en .gitignore.

# DB dedicada para E2E. Crear con:
#   createdb ipro_e2e
# o:
#   psql -c "CREATE DATABASE ipro_e2e"
# IMPORTANTE: NO uses la DB de desarrollo (ipro_portal) — globalSetup hace
# TRUNCATE de TODAS las tablas al arrancar.
DATABASE_URL=postgresql://lucasbruno@localhost:5432/ipro_e2e

# Cualquier string de ≥32 chars sirve para tests.
JWT_SECRET=e2e_test_jwt_secret_min_32_chars_padding_xyz

# 64 hex chars (32 bytes) — necesaria para 2FA. NO usar en prod.
TWOFA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
